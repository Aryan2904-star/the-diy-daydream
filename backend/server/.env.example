# ==========================================================
#  The DIY Daydream — BACKEND SERVER env
#  Copy this file to ".env" and fill in your own values.
#  (Never put real secrets in THIS file — it gets committed.)
# ==========================================================

# --- Neon Postgres (https://neon.tech) -------------------
# Create a project, then copy the two connection strings from the dashboard.
# DATABASE_URL = the POOLED string (ends with -pooler...), used at runtime.
# DIRECT_URL   = the DIRECT string (no -pooler), used by `prisma migrate`.
# Tip: keep only "?sslmode=require" at the end (drop "&channel_binding=require").
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# TIP (preview DB): create a Neon BRANCH (e.g. "preview") and keep its two
# strings in a separate ".env.preview" for staging/preview deploys.

# --- Cloudinary (https://cloudinary.com) — image uploads --
# Dashboard > Product Environment Credentials.
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# --- Auth ------------------------------------------------
# JWT_SECRET: any long random string. The admin user is created/updated by the
# seed script from ADMIN_EMAIL + ADMIN_PASSWORD.
JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="choose-a-strong-password"

# --- Networking ------------------------------------------
# Comma-separated list of allowed origins (your frontend + admin URLs).
# Local dev defaults: frontend on 5500 (Live Server), admin on 5173 (Vite).
CORS_ORIGIN="http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173"
PORT=4000
